; ─────────────────────────────────────────────────────────────────────────────
; splice-proxy config.ini
;
; Fill in the [wireguard] section with values from your WireGuard server.
; Keys are in standard WG base64 format (44 chars, ending in '='), same as
; what `wg genkey` / `wg pubkey` produce and what the reference wg-quick
; .conf files use.
; ─────────────────────────────────────────────────────────────────────────────

[proxy]
; Where the proxies listen for browser connections. Use 127.0.0.1 to keep
; them local-only, or 0.0.0.0 to expose on LAN.
http_listen   = 127.0.0.1:12346
socks5_listen = 127.0.0.1:12348

[routing]
; Route used when no hostname rule below matches.
; Valid values: wireguard, direct
default = wireguard

; 0 disables reload; a positive value polls config.ini at this interval.
; New rules affect new connections. Existing tunnels keep their original route.
reload_interval_seconds = 0

[routes]
; Per-domain outbound routing. A rule matches the domain itself and all of its
; subdomains. The longest matching domain wins. Domain-label boundaries apply:
; example.com matches a.b.example.com, but not notexample.com.
; A literal IP rule matches only that exact IP. CIDR rules match literal,
; [hosts], and DNS-resolved addresses. Exact IP wins over CIDR; otherwise the
; longest matching CIDR prefix wins.
;
; Direct routes use system DNS and the normal local network. WireGuard routes
; use the DNS servers below and the embedded tunnel.
; Hostnames found in the OS hosts file are automatically direct unless a
; matching rule here overrides that behavior. The files are /etc/hosts on Linux
; and %SystemRoot%\System32\drivers\etc\hosts on Windows. They are read at
; startup; restart splice-proxy after changing them.
; localhost, *.localhost, 127.0.0.0/8, and ::1 are also automatically direct.
;
; example.com         = direct
; secure.example.com  = wireguard
; 192.0.2.10          = direct
; 192.168.0.0/16      = direct

[wireguard]
; Your client's private key (base64).
private_key = PUT_YOUR_PRIVATE_KEY_HERE=

; The VPN server's public key (base64).
peer_public_key = PUT_SERVER_PUBLIC_KEY_HERE=

; Optional pre-shared key (base64). Leave blank if not used.
preshared_key =

; Server endpoint (host:port or ip:port).
peer_endpoint = 

; This client's IP inside the VPN. Can be comma-separated for dual-stack
; (e.g. "10.0.0.2, fd00::2"). CIDR suffix is optional and ignored.
local_ip = 10.0.0.2/32

; What traffic goes through the tunnel. For a "route everything" client,
; leave as 0.0.0.0/0. For split-tunnel, list specific CIDRs.
allowed_ips = 0.0.0.0/0, ::/0

; Keepalive pulse in seconds. 25 is the standard value — keeps NAT mappings
; alive through home routers and corporate firewalls.
persistent_keepalive = 25

; MTU inside the tunnel. 1420 is the WG default. Lower (e.g. 1280) if you're
; tunneling over another tunnel or over networks with small MTU (mobile, etc).
mtu = 1420

[dns]
; DNS servers, comma-separated. Queries are sent THROUGH the WG tunnel.
; The host OS's DNS is not touched — corporate DNS, Symantec DNS interception,
; and DNS leaks are all bypassed.
;
; Examples:
;   Cloudflare:  1.1.1.1:53, 1.0.0.1:53
;   Google:      8.8.8.8:53, 8.8.4.4:53
;   Quad9:       9.9.9.9:53
; Port :53 is added automatically if you omit it.
servers = 1.1.1.1:53, 1.0.0.1:53

; Cache TTL for DNS answers in seconds. 0 disables caching.
cache_ttl_seconds = 300

[hosts]
; Static hostname-to-IP mappings — bypass DNS for specific domains.
; Exact matches take priority over wildcards. Longest wildcard suffix wins.
; Routing checks the hostname in [routes] first, then this static IP in [routes],
; then routing.default. The static IP is used with either direct or WireGuard.
; Hosts without a mapping skip the IP-route check. These mappings do not affect
; the OS or other applications.
;
; Examples (uncomment and edit as needed):
;
; # Exact match
; gemini.google.com    = 142.250.80.110
; broken-dns-site.com  = 203.0.113.42
; legacy.internal      = 192.0.2.10  ; matches the direct IP route above
;
; # Wildcard — matches any subdomain of example.com, but NOT example.com itself
; *.example.com        = 192.0.2.10
;
; # Internal services reachable through the VPN
; api.internal         = 10.0.0.50
; *.corp.local         = 10.0.0.1
